# Flask 配置
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here
# 可选：为空时不启用登录保护
ACCESS_CODE=your-access-code-here

# 服务器配置
HOST=0.0.0.0
PORT=5090

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/meetingez.log

# 安全配置
MAX_CONTENT_LENGTH=16777216  # 16MB

# ============================================================
# Meeting Agent 配置（会议纪要整理 Agent）
# ============================================================

# 智谱 AI ASR（语音转写）
ZHIPU_API_KEY=your_zhipu_api_key_here
# ZHIPU_ASR_MODEL=glm-asr-2512  # 可选，智谱 ASR 模型名

# OpenAI GPT-5.4（纪要生成与项目记忆）
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1  # 可选，用于代理
# OPENAI_MODEL=gpt-5.4  # 可选，纪要生成模型名
# Web 端实时转写模型
# TRANSCRIPTION_MODEL=gpt-4o-transcribe  # 可选
# Web 端后置翻译模型
TRANSLATION_MODEL=gpt-5.4-mini-2026-03-17
# 可选：仅对支持 reasoning 的翻译模型生效（如 GPT-5 系列）
# 默认 low
TRANSLATION_REASONING_EFFORT=low

# 项目目录配置
# 单项目模式：直接指定会议目录
MEETINGS_DIR=./meetings
# 多项目模式：指定项目根目录（二选一）
# PROJECTS_DIR=./projects

# Agent 行为配置
RECENT_MINUTES_COUNT=5            # 参考最近 N 份纪要
DEFAULT_LANGUAGE=zh-CN            # 默认语言
TIMEZONE=Asia/Shanghai            # 时区

# ASR 配置
ASR_CHUNK_SECONDS=30              # ASR 分块时长（秒）
ASR_OVERLAP_SECONDS=2             # ASR 重叠时长（秒）
